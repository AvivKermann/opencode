{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
        "opencode-gemini-auth@1.3.10",
        "opencode-openai-codex-auth@latest"
    ],
  "model": "openai/gpt-5.5",
  "small_model": "google/gemini-2.5-flash",
  "default_agent": "kermintor",
  "permission": {
    "edit": "deny",
    "bash": {
      "*": "deny",
      "jira": "allow",
      "jira *": "allow",
      "jira*&&*": "deny",
      "jira*;*": "deny",
      "jira*|*": "deny"
    },
    "webfetch": "allow"
  }
}
